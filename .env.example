# Copy to .env.local and fill in your values (never commit .env.local).
# Alternatively configure keys in the app: Settings → API-Schlüssel (stored under data/api-keys-settings.json).

# --- Beeper Desktop API (localhost when Beeper is open) ---
BEEPER_API_URL=http://localhost:23373
BEEPER_MCP_TOKEN=your-token-from-beeper-settings-developers

# --- OpenAI (chat analysis, todo extraction, transcription, vision) ---
OPENAI_API_KEY=sk-proj-your-key-here
# Optional model overrides (defaults: gpt-4o-mini / gpt-4o)
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini
# OPENAI_TODO_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o

# --- Google Tasks OAuth (optional, for todo sync) ---
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_TASKS_REDIRECT_URI=http://localhost:3002/api/google-tasks/callback

# --- Reclaim API (optional; token can also be set in Settings → API-Schlüssel) ---
# RECLAIM_API_TOKEN=your-reclaim-api-token

# --- App / dev ---
# LOG_LEVEL=debug
# BEEPER_CRM_DATA_DIR=/custom/path/to/data
# BEEPER_CRM_DEV_POLLING=1
# TODO_ANALYSIS_TRACE=1
