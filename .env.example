# Beeper Desktop API (runs on localhost when Beeper is open)
BEEPER_API_URL=http://localhost:23373
BEEPER_MCP_TOKEN=your-token-from-beeper-settings-developers

# OpenAI (ChatGPT) for AI chat analysis and Harmonzi-style reply suggestions
OPENAI_API_KEY=sk-proj-...
# Optional: override default gpt-4o-mini (must match hash in lib/analysis-prompt-hash.ts / todo-prompt-hash if you change defaults)
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini
# OPENAI_TODO_MODEL=gpt-4o-mini

# Logging: trace | debug | info | warn | error (default: debug in dev, info in prod)
# LOG_LEVEL=debug
